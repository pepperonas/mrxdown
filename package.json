{
  "name": "mrxdown",
  "version": "0.6.2",
  "description": "Ein moderner Markdown-Editor mit Live-Vorschau",
  "main": "main.js",
  "homepage": "https://github.com/pepperonas/mrxdown",
  "repository": {
    "type": "git",
    "url": "https://github.com/pepperonas/mrxdown.git"
  },
  "bugs": {
    "url": "https://github.com/pepperonas/mrxdown/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish=never",
    "build-mac": "electron-builder --mac --publish=never",
    "build-mac-arm64": "electron-builder --mac --arm64 --publish=never",
    "build-mac-local": "electron-builder --mac --publish=never && find dist -name '*.app' -exec xattr -cr {} \\; 2>/dev/null || true",
    "build-win": "electron-builder --win --publish=never",
    "build-linux": "electron-builder --linux --publish=never",
    "build-all": "electron-builder --mac --win --linux --publish=never",
    "release": "electron-builder --publish=always",
    "release-mac": "electron-builder --mac --publish=always",
    "release-win": "electron-builder --win --publish=always",
    "release-linux": "electron-builder --linux --publish=always",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest --verbose",
    "build:editor": "esbuild src/codemirror-setup.js --bundle --outfile=vendor/codemirror-bundle.js --format=iife --global-name=CMSetup --minify"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "desktop",
    "macos",
    "windows",
    "linux",
    "live-preview",
    "dark-theme",
    "productivity"
  ],
  "author": {
    "name": "Martin Pfeffer",
    "email": "martin@pepperonas.com",
    "url": "https://pepperonas.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/highlight": "^1.2.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.pepperonas.mrxdown",
    "productName": "MrxDown",
    "artifactName": "mrxdown-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "editor-utils.js",
      "icons.js",
      "cm-adapter.js",
      "css/**/*",
      "vendor/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "type": "distribution",
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "artifactName": "mrxdown-macos-${arch}.${ext}",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "MrxDown needs access to AppleEvents for file operations.",
        "NSSystemAdministrationUsageDescription": "MrxDown needs system permissions for file management.",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown Document",
            "CFBundleTypeExtensions": [
              "md",
              "markdown"
            ],
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Owner"
          }
        ]
      },
      "notarize": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "mrxdown-windows-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Office",
      "artifactName": "mrxdown-linux-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "MrxDown ${version}",
      "format": "ULFO",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MrxDown"
    },
    "publish": {
      "provider": "github",
      "owner": "pepperonas",
      "repo": "mrxdown",
      "private": false
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "marked": "^12.0.1"
  }
}
